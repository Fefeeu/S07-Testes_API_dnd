    {
      "name": "todos_os_monstros",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const all_monsters = pm.response.json();",
              "",
              "pm.test(\"TC-026 Status de resposta deve ser 200\", function(){",
              "    pm.response.to.have.status(200)",
              "});",
              "",
              "pm.test(\"TC-027 Json possui o campo 'results' e ele não é vazio\", function(){",
              "    pm.expect(all_monsters.results).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "pm.test(\"TC-028 Campo results, uma lista com 334 itens\", function(){",
              "    pm.expect(all_monsters.results).to.have.lengthOf(334)",
              "});",
              "",
              "pm.test(\"TC-029 Campo 'count' deve ter o mesmo valor que a quantidade na lista 'results'\", function(){",
              "    pm.expect(all_monsters.count).to.equal(all_monsters.results.length)",
              "});",
              "",
              "pm.test(\"TC-030 Todos os monstros devem ter os campos essenciais\", function() {",
              "    ",
              "    const listaReduzida = all_monsters.results.slice(0, 20);",
              "    // !A LISTA ESTA REDUZIDA UNICA E EXCLUSIVAMENTE PARA O postman E A api NÃO BARRAR TANTAS REQUISIÇÕES!",
              "    listaReduzida.forEach((monsterRef) => {",
              "        const URLcompleta = \"https://www.dnd5eapi.co\" + monsterRef.url;",
              "",
              "        pm.sendRequest(URLcompleta, (error, response) => {",
              "            if(error) {",
              "                console.error(`Erro ao chamar ${monsterRef.name}: ${error}`);",
              "                return;",
              "            }",
              "",
              "            const monster = response.json()",
              "            const mensagem_erro = `Verifica falha na integridade do monstro: ${monster.name || 'Sem Nome'}`",
              "        ",
              "            pm.test(`${mensagem_erro}`, function () {",
              "                pm.expect(monster.index, mensagem_erro).to.be.a('string').and.not.empty;",
              "                pm.expect(monster.name, mensagem_erro).to.be.a('string').and.not.empty;",
              "                pm.expect(monster.url, mensagem_erro).to.be.a('string').and.include('/monsters/');",
              "                ",
              "                pm.expect(monster.size, mensagem_erro).to.be.a('string').and.not.empty;",
              "                pm.expect(monster.type, mensagem_erro).to.be.a('string').and.not.empty;",
              "                pm.expect(monster.alignment, mensagem_erro).to.be.a('string').and.not.empty;",
              "",
              "                pm.expect(monster.armor_class, mensagem_erro).to.be.an('array').and.not.empty;",
              "                pm.expect(monster.hit_points, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.hit_dice, mensagem_erro).to.be.a('string').and.not.empty;",
              "                pm.expect(monster.hit_points_roll, mensagem_erro).to.be.a('string').and.not.empty;",
              "",
              "                pm.expect(monster.strength, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.dexterity, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.constitution, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.intelligence, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.wisdom, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.charisma, mensagem_erro).to.be.a('number');",
              "",
              "                pm.expect(monster.xp, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.challenge_rating, mensagem_erro).to.be.a('number');",
              "                pm.expect(monster.proficiency_bonus, mensagem_erro).to.be.a('number');",
              "                ",
              "                pm.expect(monster.speed, mensagem_erro).to.be.an('object').and.not.empty;",
              "                pm.expect(monster.image, mensagem_erro).to.be.a('string').and.include('/images/');",
              "            });",
              "        });",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
