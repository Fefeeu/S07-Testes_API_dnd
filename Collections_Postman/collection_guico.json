          "name": "classe_clerigo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const returnal = pm.response.json();\r",
                  "\r",
                  "pm.test('TC-069 Deve possuir o campo spellcasting', function ()\r",
                  "{\r",
                  "    pm.expect(returnal).to.have.property('spellcasting');\r",
                  "});\r",
                  "\r",
                  "pm.test('TC-070 O campo spellcasting_ability.index deve ser igual ao valor wis', function()\r",
                  "{\r",
                  "    pm.expect(returnal.spellcasting.spellcasting_ability.index).to.equal('wis');\r",
                  "});\r",
                  "\r",
                  "pm.test('TC-071 Não deve existir proficiency com index \"all-armor\"', function () \r",
                  "{\r",
                  "    const hasHeavyArmor = returnal.proficiencies.some(p => p.index === \"all-armor\");\r",
                  "    pm.expect(hasHeavyArmor).to.be.false;\r",
                  "});\r",
                  "\r",
                  "pm.test('TC-072 Não deve conter saving throws inválidos para a classe clerigo', function () \r",
                  "{\r",
                  "    const indexes = returnal.saving_throws.map(s => s.index);\r",
                  "    const proibidos = ['str', 'dex', 'con', 'int']; // Lista de saving throws proibidos para a classe cleric\r",
                  "    const temProibido = indexes.some(i => proibidos.includes(i));\r",
                  "    pm.expect(temProibido).to.be.false;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
