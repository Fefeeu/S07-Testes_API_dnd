      "name": "Trabalho S07",
      "item": [
        {
          "name": "todas_as_classes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const returnal = pm.response.json();\r",
                  "\r",
                  "pm.test('TC-064 Status deve ser 200', function ()\r",
                  "{\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('TC-065 Contagem deve ser 12', function ()\r",
                  "{\r",
                  "    pm.expect(returnal.count).to.equal(12);\r",
                  "});\r",
                  "\r",
                  "pm.test('TC-066 O indice da primeira classe deve ser \"barbarian\"', function ()\r",
                  "{\r",
                  "    pm.expect(returnal.results[0].index).to.equal(\"barbarian\");\r",
                  "});\r",
                  "\r",
                  "pm.test('TC-067 Todas as classes devem ter somente index, name e url', function()\r",
                  "{\r",
                  "    returnal.results.forEach(function(item)\r",
                  "    {\r",
                  "        const keys = Object.keys(item);\r",
                  "        pm.expect(keys).to.have.members(['index', 'name', 'url']);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test('TC-068 O endpoint deve terminar com o mesmo valor do index', function()\r",
                  "{\r",
                  "    returnal.results.forEach(function(item)\r",
                  "    {\r",
                  "        const urlParts = item.url.split('/');\r",
                  "        const endpointName = urlParts[urlParts.length - 1];\r",
                  "\r",
                  "        pm.expect(endpointName).to.equal(item.index);\r",
                  "    });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
