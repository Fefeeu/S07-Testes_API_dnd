    {
      "name": "monstro_aboleth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const monster = pm.response.json();",
              "",
              "pm.test(\"Validar integridade dos dados detalhados do Aboleth\", function () {",
              "    pm.expect(monster.index).to.equal(\"aboleth\");",
              "    pm.expect(monster.name).to.equal(\"Aboleth\");",
              "    pm.expect(monster.size).to.equal(\"Large\");",
              "    pm.expect(monster.type).to.equal(\"aberration\");",
              "    pm.expect(monster.alignment).to.equal(\"lawful evil\");",
              "",
              "    pm.expect(monster.strength).to.equal(21);",
              "    pm.expect(monster.dexterity).to.equal(9);",
              "    pm.expect(monster.constitution).to.equal(15);",
              "    pm.expect(monster.intelligence).to.equal(18);",
              "    pm.expect(monster.wisdom).to.equal(15);",
              "    pm.expect(monster.charisma).to.equal(18);",
              "",
              "    pm.expect(monster.hit_points).to.equal(135);",
              "    pm.expect(monster.hit_dice).to.equal(\"18d10\");",
              "    pm.expect(monster.hit_points_roll).to.equal(\"18d10+36\");",
              "    pm.expect(monster.armor_class[0].value).to.equal(17);",
              "    pm.expect(monster.armor_class[0].type).to.equal(\"natural\");",
              "",
              "    pm.expect(monster.speed.walk).to.equal(\"10 ft.\");",
              "    pm.expect(monster.speed.swim).to.equal(\"40 ft.\");",
              "",
              "    pm.expect(monster.challenge_rating).to.equal(10);",
              "    pm.expect(monster.xp).to.equal(5900);",
              "    pm.expect(monster.proficiency_bonus).to.equal(4);",
              "",
              "    pm.expect(monster.image).to.equal(\"/api/images/monsters/aboleth.png\");",
              "    pm.expect(monster.url).to.equal(\"/api/2014/monsters/aboleth\");",
              "});",
              "",
              "pm.test(\"Validar existência de proficiências e ações\", function () {",
              "    pm.expect(monster.proficiencies).to.be.an('array').and.not.empty;",
              "    pm.expect(monster.actions).to.be.an('array').and.not.empty;",
              "    pm.expect(monster.special_abilities).to.be.an('array').and.not.empty;",
              "    pm.expect(monster.legendary_actions).to.be.an('array').and.not.empty;",
              "});",
              "",
              "pm.test(\"Valida se o campo 'speed' é um objeto\", function(){",
              "    pm.expect(monster.speed).to.be.an('object')",
              "});",
              "",
              "// teste Inválido",
              "pm.test(\"Aboleth não possui habilidade de Spellcasting\", function () {",
              "    const temSpellcasting = monster.special_abilities.some(",
              "        (habilidade) => habilidade.name === \"Spellcasting\"",
              "    );",
              "    pm.expect(temSpellcasting).to.be.false;",
              "});",
              "",
              "pm.test(\"Tempo de resposta a baixo do limite de tempo\", function(){",
              "    pm.expect(pm.response.responseTime).to.be.below(1000)",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
